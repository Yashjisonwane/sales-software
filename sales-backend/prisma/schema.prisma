// This is your Prisma schema file.
// It maps out the exact Data Flow we created in documentation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// ENUMS (Predefined Values)
// ---------------------------------------------------------------------
enum Role {
  ADMIN
  WORKER
  CUSTOMER
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  ESTIMATED
  INVOICED
  COMPLETED
  CANCELLED
}

enum LeadStatus {
  OPEN
  ASSIGNED
  REJECTED
}

// ---------------------------------------------------------------------
// MODELS
// ---------------------------------------------------------------------

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String   @unique
  password    String
  role        Role     @default(CUSTOMER)
  
  // Worker Specific Fields
  isAvailable Boolean  @default(true) @map("is_available")
  lat         Float?   // For Geo-location Routing
  lng         Float?   // For Geo-location Routing
  fcmToken    String?  @map("fcm_token") // For Firebase Push Notifications

  // Relations
  leadsAsCustomer Lead[]    @relation("CustomerLeads")
  jobsAsCustomer  Job[]     @relation("CustomerJobs")
  jobsAsWorker    Job[]     @relation("WorkerJobs")
  categories      WorkerCategory[]
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "Plumbing", "Electrical", "Cleaning"
  icon      String?
  
  workers   WorkerCategory[]
  leads     Lead[]
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

// Many-to-Many relation mapping for Worker <-> Category
model WorkerCategory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@map("worker_categories")
}

model Lead {
  id          String     @id @default(uuid())
  customerId  String     @map("customer_id")
  categoryId  String     @map("category_id")
  location    String
  description String?    @db.Text
  status      LeadStatus @default(OPEN)
  
  // Relations
  customer    User       @relation("CustomerLeads", fields: [customerId], references: [id])
  category    Category   @relation(fields: [categoryId], references: [id])
  job         Job?
  
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("leads")
}

model Job {
  id             String    @id @default(uuid())
  leadId         String?   @unique @map("lead_id") // Unique required for 1-to-1 connection
  customerId     String    @map("customer_id")
  workerId       String    @map("worker_id")
  categoryName   String    @map("category_name")
  status         JobStatus @default(SCHEDULED)
  
  location       String
  description    String?   @db.Text
  
  scheduledDate  DateTime  @map("scheduled_date")
  scheduledTime  String    @map("scheduled_time")
  
  // Relations
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer       User      @relation("CustomerJobs", fields: [customerId], references: [id])
  worker         User      @relation("WorkerJobs", fields: [workerId], references: [id])
  
  // Workflow Entities (1-to-Many & 1-to-1 relationships)
  photos         JobPhoto[]
  inspection     JobInspection?
  estimate       JobEstimate?
  contract       JobContract?
  invoice        JobInvoice?

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("jobs")
}

// ---------------------------------------------------------------------
// WORKFLOW MODELS
// ---------------------------------------------------------------------

model JobPhoto {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  url       String
  type      String   @default("BEFORE") // BEFORE, PROCESS, AFTER
  
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("job_photos")
}

model JobInspection {
  id        String   @id @default(uuid())
  jobId     String   @unique @map("job_id")
  notes     String   @db.Text
  signature String?  // URL to customer signature
  
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("job_inspections")
}

model JobEstimate {
  id         String   @id @default(uuid())
  jobId      String   @unique @map("job_id")
  amount     Float
  details    String   @db.Text // JSON stringified items or text
  isApproved Boolean  @default(false) @map("is_approved")
  
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("job_estimates")
}

model JobContract {
  id                String   @id @default(uuid())
  jobId             String   @unique @map("job_id")
  documentUrl       String   @map("document_url")
  signedByCustomer  Boolean  @default(false) @map("signed_by_customer")
  customerSignature String?  @map("customer_signature") // URL to signature image
  
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("job_contracts")
}

model JobInvoice {
  id          String   @id @default(uuid())
  jobId       String   @unique @map("job_id")
  amount      Float
  status      String   @default("UNPAID") // UNPAID, PAID
  paymentId   String?  @map("payment_id") // Stripe/Payment Gateway Transaction ID
  
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("job_invoices")
}
