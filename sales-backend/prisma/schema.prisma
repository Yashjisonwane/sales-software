generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model User {
  id                    String    @id @default(uuid())
  name                  String
  email                 String    @unique
  phone                 String    @unique
  password              String
  role                  Role      @default(CUSTOMER)
  isAvailable           Boolean   @default(true) @map("is_available")
  lat                   Float?
  lng                   Float?
  fcmToken              String?   @map("fcm_token")
  address               String?   @db.Text
  city                  String?
  state                 String?
  pincode               String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  planId                String?   @map("plan_id")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  completedJobs         Int       @default(0) @map("completed_jobs")
  rating                Float     @default(0)
  availability          String?
  bio                   String?   @db.Text
  businessName          String?   @map("business_name")
  experience            String?
  serviceRadius         Int?      @default(15) @map("service_radius")

  // Relations
  jobs                  Job[]     @relation("WorkerJobs")
  customerJobs          Job[]     @relation("CustomerJobs")
  leads                 Lead[]
  upgradeRequests       SubscriptionUpgradeRequest[]
  notifications         Notification[]
  plan                  SubscriptionPlan? @relation(fields: [planId], references: [id])
  categories            WorkerCategory[]

  @@map("users")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  leads     Lead[]
  workers   WorkerCategory[]

  @@map("categories")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model WorkerCategory {
  id         String @id @default(uuid())
  userId     String @map("user_id")
  categoryId String @map("category_id")

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("worker_categories")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Lead {
  id            String     @id @default(uuid())
  leadNo        String     @default(cuid()) @map("lead_no")
  customerId    String     @map("customer_id")
  categoryId    String     @map("category_id")
  location      String
  description   String?    @db.Text
  servicePlan   String     @default("Starter") @map("service_plan")
  status        LeadStatus @default(OPEN)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  preferredDate String?    @map("preferred_date")

  // Relations
  customer    User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id])
  job         Job?

  @@map("leads")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Job {
  id            String    @id @default(uuid())
  jobNo         String    @default(cuid()) @map("job_no")
  leadId        String?   @unique @map("lead_id")
  customerId    String    @map("customer_id")
  workerId      String    @map("worker_id")
  categoryName  String    @map("category_name")
  status        JobStatus @default(SCHEDULED)
  location      String
  description   String?   @db.Text
  scheduledDate DateTime  @map("scheduled_date")
  scheduledTime String    @map("scheduled_time")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  preferredDate String?   @map("preferred_date")

  // Relations
  lead       Lead?          @relation(fields: [leadId], references: [id])
  customer   User           @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  worker     User           @relation("WorkerJobs", fields: [workerId], references: [id], onDelete: Cascade)
  photos     JobPhoto[]
  inspection JobInspection?
  estimate   JobEstimate?
  invoices   JobInvoice[]
  contracts  JobContract[]

  @@map("jobs")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model JobPhoto {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  url       String
  type      String   @default("BEFORE")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_photos")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model JobInspection {
  id            String   @id @default(uuid())
  jobId         String   @unique @map("job_id")
  notes         String   @db.Text
  triageAnswers Json?    @map("triage_answers")
  signature     String?
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_inspections")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model JobEstimate {
  id           String   @id @default(uuid())
  jobId        String   @unique @map("job_id")
  amount       Float
  details      String   @db.Text
  materials    Json?
  laborHours   Float?   @map("labor_hours")
  measurements Json?
  isApproved   Boolean  @default(false) @map("is_approved")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_estimates")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model JobContract {
  id                String   @id @default(uuid())
  jobId             String   @map("job_id")
  documentUrl       String   @map("document_url")
  signedByCustomer  Boolean  @default(false) @map("signed_by_customer")
  customerSignature String?  @map("customer_signature")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_contracts")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model JobInvoice {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  amount    Float
  status    String   @default("UNPAID")
  paymentId String?  @map("payment_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_invoices")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Location {
  id        String   @id @default(uuid())
  name      String
  city      String
  state     String
  country   String   @default("USA")
  status    String   @default("Active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model SubscriptionPlan {
  id        String   @id @default(uuid())
  name      String
  price     Float
  leads     Int      @default(0)
  features  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  users           User[]
  upgradeRequests SubscriptionUpgradeRequest[]

  @@map("subscription_plans")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model SubscriptionUpgradeRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  planId    String   @map("plan_id")
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscription_upgrade_requests")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ProfessionalRequest {
  id            String   @id @default(uuid())
  name          String
  businessName  String?  @map("business_name")
  email         String
  phone         String
  category      String
  address       String?  @db.Text
  city          String?
  state         String?
  pincode       String?
  preferredPlan String   @map("preferred_plan")
  status        String   @default("PENDING")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("professional_requests")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum Role {
  ADMIN
  WORKER
  CUSTOMER
}

enum JobStatus {
  SCHEDULED
  ACCEPTED
  REJECTED
  IN_PROGRESS
  ESTIMATED
  INVOICED
  COMPLETED
  CANCELLED
}

enum LeadStatus {
  OPEN
  ASSIGNED
  REJECTED
}
